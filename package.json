{
  "name": "open-zread",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "dev": "bun run cli/src/index.tsx",
    "build": "turbo build",
    "build:cli": "cd cli && bun run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "react-devtools-core": "^4.28.5"
  },
  "workspaces": [
    "cli",
    "packages/*"
