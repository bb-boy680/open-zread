{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "types": [
      "node",
      "bun-types"
    ],
    "paths": {
      "@open-zread/types": [
        "./packages/types/src/index.ts"
      ],
      "@open-zread/utils": [
        "./packages/utils/src/index.ts"
      ],
      "@open-zread/repo-analyzer": [
        "./packages/repo-analyzer/src/index.ts"
      ],
      "@open-zread/agent-sdk": [
        "./packages/agent-sdk/src/index.ts"
      ],
      "@open-zread/orchestrator": [
        "./packages/orchestrator/src/index.ts"
      ]
    }
  },
  "include": [
    "*.ts",
    "cli/src/**/*",
    "cli/scripts/**/*",
    "packages/*/src/**/*"
  ]
}
