{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "types": ["node", "bun-types"]
  },
  "include": [
    "*.ts",
    "cli/src/**/*",
    "cli/scripts/**/*",
    "packages/*/src/**/*"
  ]
}
